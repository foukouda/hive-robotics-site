# Copy this file to `.env.local` for local dev, and configure the same
# variables in Vercel → Settings → Environment Variables (Production + Preview).

# --- Supabase (BDD reservations + RPC + Realtime) ---
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role: serveur uniquement, jamais exposé au client. Bypass RLS, utilisé par le webhook Stripe.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Stripe ---
# Mode test pour dev / preview, mode live pour prod.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Price ID 1 € EUR « one-time » créé dans Stripe (mode test ET live, IDs différents).
STRIPE_PRICE_ID=price_...
# Webhook signing secret. En local: fourni par `stripe listen`.
# En prod: dashboard Stripe → Webhooks → endpoint configuré sur /api/webhooks/stripe (event checkout.session.completed).
STRIPE_WEBHOOK_SECRET=whsec_...

# --- App ---
# URL publique de l'app. En local: http://localhost:3000. En prod: https://hiverobotics.fr.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Resend (emails post-paiement) ---
RESEND_API_KEY=re_...
# Expéditeur. Le domaine doit être vérifié dans Resend (DKIM/SPF/MX).
RESEND_FROM_EMAIL=Hive Robotics <noreply@hiverobotics.fr>
# Destinataires de la notif interne « nouveau lead », séparés par des virgules.
INTERNAL_NOTIFICATION_EMAILS=teddy.leclercq@hiverobotics.fr,thomas.raynal@hiverobotics.fr

# --- Mapbox (carte landing page) ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk....
